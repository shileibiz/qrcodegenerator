---
import Layout from '../layouts/Layout.astro';

const title = 'Privacy Policy — QRMint';
const description = 'Privacy Policy for QRMint — free QR code generator. Your data stays in your browser.';
const canonical = new URL('/privacy/', Astro.site).href;
---

<Layout title={title} description={description} canonical={canonical}>
  <header class="border-b border-slate-200 bg-white sticky top-0 z-20">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
      <a href="/" class="flex items-center gap-2 text-lg font-bold text-brand-700">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="14" y="2" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="2" y="14" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="14" y="14" width="3.5" height="3.5" rx="1" fill="#60a5fa" />
          <rect x="18.5" y="18.5" width="3.5" height="3.5" rx="1" fill="#60a5fa" />
        </svg>
        QRMint
      </a>
      <a
        href="/"
        class="rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
      >
        ← Back to Home
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-12">
    <article class="prose prose-slate max-w-none">
      <h1>Privacy Policy</h1>
      <p class="text-sm text-slate-500"><strong>Last updated:</strong> July 22, 2026</p>

      <h2>1. Introduction</h2>
      <p>QRMint ("we", "our", or "us") operates the website qrmint.app (the "Service"). This Privacy Policy explains how we handle your information when you use our free online QR code generator.</p>

      <h2>2. No Data Collection</h2>
      <p><strong>QRMint is a 100% client-side application.</strong> All QR code generation — for URLs, text, WiFi, and vCards — happens in your browser using JavaScript. We do not:</p>
      <ul>
        <li>Collect, store, or transmit any data you enter (URLs, WiFi passwords, contact details)</li>
        <li>Use cookies for tracking or analytics</li>
        <li>Upload your generated codes or designs to any server</li>
        <li>Require registration, login, or email address for static QR codes</li>
        <li>Track your usage across sessions</li>
      </ul>

      <h2>3. Local Storage</h2>
      <p>The tool may use your browser's localStorage to remember your preferences. This data stays on your device and is never sent to our servers.</p>

      <h2>4. Third-Party Services</h2>
      <p>This website is hosted on <strong>Cloudflare Pages</strong>. Cloudflare processes minimal, anonymized request data for the sole purpose of delivering the website. We do not use Google Analytics or any other third-party analytics services.</p>

      <h2>5. Cookies</h2>
      <p>This website does not set any non-essential cookies. Cloudflare Pages may set strictly functional cookies required for CDN operation.</p>

      <h2>6. Children's Privacy</h2>
      <p>Our Service does not address anyone under the age of 13.</p>

      <h2>7. Changes</h2>
      <p>We may update this Privacy Policy from time to time. Changes will be posted on this page.</p>

      <h2>8. Contact</h2>
      <p>Questions? Contact us at: <a href="mailto:privacy@qrmint.app">privacy@qrmint.app</a></p>
    </article>
  </main>
</Layout>
