---
import Layout from '../layouts/Layout.astro';

const title = 'Terms of Service — QRMint';
const description = 'Terms of Service for QRMint — free online QR code generator.';
const canonical = new URL('/terms/', Astro.site).href;
---

<Layout title={title} description={description} canonical={canonical}>
  <header class="border-b border-slate-200 bg-white sticky top-0 z-20">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
      <a href="/" class="flex items-center gap-2 text-lg font-bold text-brand-700">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="14" y="2" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="2" y="14" width="8" height="8" rx="1.5" fill="#2563eb" />
          <rect x="14" y="14" width="3.5" height="3.5" rx="1" fill="#60a5fa" />
          <rect x="18.5" y="18.5" width="3.5" height="3.5" rx="1" fill="#60a5fa" />
        </svg>
        QRMint
      </a>
      <a
        href="/"
        class="rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
      >
        ← Back to Home
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-12">
    <article class="prose prose-slate max-w-none">
      <h1>Terms of Service</h1>
      <p class="text-sm text-slate-500"><strong>Last updated:</strong> July 22, 2026</p>

      <h2>1. Acceptance of Terms</h2>
      <p>By accessing or using QRMint ("the Service"), you agree to be bound by these Terms of Service.</p>

      <h2>2. Service Description</h2>
      <p>QRMint is a free, browser-based QR code generator. You can create static QR codes for URLs, text, WiFi networks, and vCards. All generation is performed locally in your browser. Premium features (dynamic codes with editing and scan tracking) are available as a paid upgrade.</p>

      <h2>3. Disclaimer of Warranties</h2>
      <p>THE SERVICE IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT ANY WARRANTY OF ANY KIND. WE DO NOT GUARANTEE THAT THE SERVICE WILL BE UNINTERRUPTED, TIMELY, SECURE, OR ERROR-FREE. QR CODE SCANNABILITY DEPENDS ON PRINT QUALITY, SIZE, AND SCANNER CAPABILITY.</p>

      <h2>4. Limitation of Liability</h2>
      <p>IN NO EVENT SHALL QRMINT, ITS OPERATORS, OR AFFILIATES BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES ARISING FROM YOUR USE OF THE SERVICE.</p>

      <h2>5. User Responsibilities</h2>
      <p>You agree to use the Service responsibly. You must not generate QR codes that link to illegal, harmful, or fraudulent content.</p>

      <h2>6. Intellectual Property</h2>
      <p>The QRMint name, logo, and website content are our property. Generated QR codes are yours to use for any lawful purpose.</p>

      <h2>7. Premium Services</h2>
      <p>Premium features are paid services. We reserve the right to modify pricing and feature availability with notice.</p>

      <h2>8. Changes</h2>
      <p>We may modify these terms at any time. Changes will be posted on this page.</p>

      <h2>9. Contact</h2>
      <p>Questions: <a href="mailto:legal@qrmint.app">legal@qrmint.app</a></p>
    </article>
  </main>
</Layout>
