---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Bulk QR Code Generator — Generate 100+ QR Codes Free | QRMint';
const description = 'Generate hundreds of QR codes at once from a CSV file. Free, no sign-up, runs entirely in your browser. Download as ZIP.';

const canonical = new URL('/bulk/', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Bulk QR Code Generator — QRMint',
  url: canonical,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Any (Web Browser)',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const comparisons = [
  { tool: 'QRMint (this)', max_batch: 'Unlimited (browser RAM)', signup: 'None', cost: 'Free', format: 'PNG / SVG / ZIP' },
  { tool: 'Bitly bulk', max_batch: '500 / batch', signup: 'Required', cost: '$8/mo', format: 'PNG' },
  { tool: 'QR Code Monkey', max_batch: '100 / batch', signup: 'Not required', cost: 'Free (with limits)', format: 'PNG / EPS / SVG' },
  { tool: 'QR.io bulk', max_batch: '200 / batch', signup: 'Required', cost: '$7/mo', format: 'PNG / SVG' },
];
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-10">
    <section class="text-center">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">Bulk QR Code Generator</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        Upload a CSV with your URLs or text, and generate all the QR codes at once. No sign-up, no limits, 
        no server upload — it all runs right in your browser.
      </p>
    </section>

    <section class="mt-10 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-bold text-slate-900">How It Works</h2>
      <ol class="mt-4 list-inside list-decimal space-y-2 text-slate-700">
        <li>Prepare a CSV file with one column: your URLs or text lines</li>
        <li>Upload the CSV (or paste the data)</li>
        <li>Choose size, format, and error correction level</li>
        <li>Click generate — all QR codes render in your browser</li>
        <li>Download individual images or a ZIP bundle</li>
      </ol>
      <div class="mt-4 rounded-lg bg-slate-50 p-4 text-sm text-slate-600">
        <p class="font-medium text-slate-700">CSV format example:</p>
        <code class="block mt-1 whitespace-pre font-mono text-xs">url
https://example.com/page1
https://example.com/page2
https://example.com/page3</code>
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Bulk Tool Comparison</h2>
      <div class="mt-4 overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 font-semibold text-slate-700">Tool</th>
              <th class="px-4 py-3 font-semibold text-slate-700">Max batch</th>
              <th class="px-4 py-3 font-semibold text-slate-700">Sign-up</th>
              <th class="px-4 py-3 font-semibold text-slate-700">Cost</th>
              <th class="px-4 py-3 font-semibold text-slate-700">Format</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {comparisons.map((row) => (
              <tr>
                <td class="px-4 py-3 font-medium text-slate-800">{row.tool}</td>
                <td class="px-4 py-3 text-slate-600">{row.max_batch}</td>
                <td class="px-4 py-3">{row.signup === 'None' ? <span class="text-green-600">None ✓</span> : <span class="text-slate-600">{row.signup}</span>}</td>
                <td class="px-4 py-3 text-slate-600">{row.cost}</td>
                <td class="px-4 py-3 text-slate-600">{row.format}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 rounded-xl border border-brand-200 bg-brand-50 p-6 text-center">
      <a href="/" class="inline-block rounded-full bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Go to the QR tool →</a>
      <p class="mt-2 text-sm text-slate-500">Bulk CSV support is available on the homepage. Paste your data or upload a CSV file.</p>
    </section>

    <section class="mt-12 space-y-4">
      <h2 class="text-2xl font-bold text-slate-900">FAQ</h2>
      <details class="rounded-xl border border-slate-200 p-4">
        <summary class="cursor-pointer font-medium text-slate-800">How many QR codes can I generate at once?</summary>
        <p class="mt-2 text-sm text-slate-600">As many as your browser can handle. For 100-500 codes there should be no issue. For 10,000+, your browser may slow down. We recommend splitting large batches into groups of 1,000.</p>
      </details>
      <details class="rounded-xl border border-slate-200 p-4">
        <summary class="cursor-pointer font-medium text-slate-800">What file formats are supported?</summary>
        <p class="mt-2 text-sm text-slate-600">PNG and SVG. PNG for print and web, SVG for vector editing in tools like Illustrator or Inkscape. ZIP download bundles all images together.</p>
      </details>
      <details class="rounded-xl border border-slate-200 p-4">
        <summary class="cursor-pointer font-medium text-slate-800">Is my data safe when uploading a CSV?</summary>
        <p class="mt-2 text-sm text-slate-600">Yes — the CSV is read entirely in your browser using JavaScript's FileReader API. No data is uploaded to any server. Once you close the tab, everything disappears.</p>
      </details>
    </section>
  </main>
  <Footer />
</Layout>
