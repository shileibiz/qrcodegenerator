---
export interface Props {
  defaultTab?: 'text' | 'url' | 'wifi' | 'vcard';
}

const { defaultTab = 'url' } = Astro.props;

const tabs = [
  { id: 'text', label: 'Text' },
  { id: 'url', label: 'URL' },
  { id: 'wifi', label: 'WiFi' },
  { id: 'vcard', label: 'vCard' },
];
---

<section
  id="qr-tool"
  data-default-tab={defaultTab}
  class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6"
>
  <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
    <!-- Input side -->
    <div>
      <div role="tablist" aria-label="QR code type" class="flex flex-wrap gap-2">
        {tabs.map((tab) => (
          <button
            type="button"
            role="tab"
            data-tab={tab.id}
            class="qr-tab rounded-full border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:border-brand-300 hover:text-brand-600"
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Text panel -->
      <div data-panel="text" class="qr-panel mt-5 hidden">
        <label for="qr-text" class="block text-sm font-medium text-slate-700">Your text</label>
        <textarea
          id="qr-text"
          rows="4"
          maxlength="1500"
          placeholder="Type any text — notes, serial numbers, coupon codes..."
          class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
        ></textarea>
      </div>

      <!-- URL panel -->
      <div data-panel="url" class="qr-panel mt-5 hidden">
        <label for="qr-url" class="block text-sm font-medium text-slate-700">Website URL</label>
        <input
          id="qr-url"
          type="url"
          inputmode="url"
          placeholder="https://example.com"
          class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
        />
      </div>

      <!-- WiFi panel -->
      <div data-panel="wifi" class="qr-panel mt-5 hidden">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="wifi-ssid" class="block text-sm font-medium text-slate-700">Network name (SSID)</label>
            <input
              id="wifi-ssid"
              type="text"
              placeholder="MyHomeWiFi"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            />
          </div>
          <div>
            <label for="wifi-pass" class="block text-sm font-medium text-slate-700">Password</label>
            <input
              id="wifi-pass"
              type="text"
              autocomplete="off"
              placeholder="Network password"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            />
          </div>
          <div>
            <label for="wifi-enc" class="block text-sm font-medium text-slate-700">Encryption</label>
            <select
              id="wifi-enc"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            >
              <option value="WPA" selected>WPA / WPA2 / WPA3</option>
              <option value="WEP">WEP</option>
              <option value="nopass">None (open network)</option>
            </select>
          </div>
          <label class="mt-8 flex items-center gap-2 text-sm text-slate-700">
            <input id="wifi-hidden" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-600" />
            Hidden network
          </label>
        </div>
        <p class="mt-3 text-xs text-slate-500">
          Your WiFi details never leave this page — the code is generated entirely in your browser.
        </p>
      </div>

      <!-- vCard panel -->
      <div data-panel="vcard" class="qr-panel mt-5 hidden">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="vc-first" class="block text-sm font-medium text-slate-700">First name</label>
            <input id="vc-first" type="text" placeholder="Jane"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
          <div>
            <label for="vc-last" class="block text-sm font-medium text-slate-700">Last name</label>
            <input id="vc-last" type="text" placeholder="Doe"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
          <div>
            <label for="vc-phone" class="block text-sm font-medium text-slate-700">Phone</label>
            <input id="vc-phone" type="tel" placeholder="+1 555 123 4567"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
          <div>
            <label for="vc-email" class="block text-sm font-medium text-slate-700">Email</label>
            <input id="vc-email" type="email" placeholder="jane@example.com"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
          <div>
            <label for="vc-org" class="block text-sm font-medium text-slate-700">Company (optional)</label>
            <input id="vc-org" type="text" placeholder="Acme Inc."
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
          <div>
            <label for="vc-url" class="block text-sm font-medium text-slate-700">Website (optional)</label>
            <input id="vc-url" type="url" placeholder="https://example.com"
              class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
          </div>
        </div>
      </div>

      <!-- Options -->
      <div class="mt-6 border-t border-slate-100 pt-5">
        <h3 class="text-sm font-semibold text-slate-700">Customize</h3>
        <div class="mt-3 grid gap-4 sm:grid-cols-2">
          <div>
            <label for="qr-logo" class="block text-sm font-medium text-slate-700">Logo (optional)</label>
            <input
              id="qr-logo"
              type="file"
              accept="image/png,image/jpeg,image/svg+xml,image/webp"
              class="mt-2 w-full text-sm text-slate-600 file:mr-3 file:rounded-full file:border-0 file:bg-brand-50 file:px-4 file:py-2 file:text-sm file:font-medium file:text-brand-700 hover:file:bg-brand-100"
            />
            <button
              type="button"
              id="qr-logo-remove"
              class="mt-1 hidden text-xs text-slate-500 underline hover:text-brand-600"
            >
              Remove logo
            </button>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="qr-fg" class="block text-sm font-medium text-slate-700">Color</label>
              <input id="qr-fg" type="color" value="#1e293b" class="mt-2 h-10 w-full cursor-pointer rounded-lg border border-slate-300" />
            </div>
            <div>
              <label for="qr-bg" class="block text-sm font-medium text-slate-700">Background</label>
              <input id="qr-bg" type="color" value="#ffffff" class="mt-2 h-10 w-full cursor-pointer rounded-lg border border-slate-300" />
            </div>
          </div>
          <div>
            <label for="qr-size" class="block text-sm font-medium text-slate-700">Download size</label>
            <select id="qr-size" class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200">
              <option value="512">512 × 512 px</option>
              <option value="1024" selected>1024 × 1024 px</option>
              <option value="2048">2048 × 2048 px (print)</option>
            </select>
          </div>
          <div>
            <label for="qr-ecl" class="block text-sm font-medium text-slate-700">Error correction</label>
            <select id="qr-ecl" class="mt-2 w-full rounded-xl border border-slate-300 p-3 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200">
              <option value="L">Low (7%)</option>
              <option value="M" selected>Medium (15%)</option>
              <option value="Q">Quartile (25%)</option>
              <option value="H">High (30%) — best with logo</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Preview side -->
    <div class="flex flex-col items-center">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <canvas id="qr-canvas" width="272" height="272" class="h-[272px] w-[272px] rounded-lg bg-white"></canvas>
      </div>
      <p id="qr-hint" class="mt-3 text-center text-xs text-slate-500">
        Start typing — your QR code updates live.
      </p>
      <div class="mt-4 flex w-full flex-col gap-2">
        <button
          type="button"
          id="qr-download-png"
          class="w-full rounded-full bg-brand-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700 disabled:cursor-not-allowed disabled:bg-slate-300"
          disabled
        >
          ⬇ Download PNG
        </button>
        <button
          type="button"
          id="qr-download-svg"
          class="w-full rounded-full border border-brand-600 px-5 py-3 text-sm font-semibold text-brand-700 transition hover:bg-brand-50 disabled:cursor-not-allowed disabled:border-slate-300 disabled:text-slate-400"
          disabled
        >
          ⬇ Download SVG
        </button>
      </div>
      <p class="mt-3 text-center text-xs text-slate-400">
        Free forever · static codes never expire
      </p>
    </div>
  </div>
</section>

<script>
  import QRCode from 'qrcode';

  const root = document.getElementById('qr-tool');
  if (root) {
    const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
    const canvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
    const hint = document.getElementById('qr-hint');
    const pngBtn = document.getElementById('qr-download-png') as HTMLButtonElement;
    const svgBtn = document.getElementById('qr-download-svg') as HTMLButtonElement;
    const tabButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('.qr-tab'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.qr-panel'));

    let activeTab = root.dataset.defaultTab || 'url';
    let logoImage: HTMLImageElement | null = null;
    let currentPayload = '';

    const PREVIEW_SIZE = 272;

    // WiFi payload fields must escape \ ; , " :
    const escapeWifi = (value: string) => value.replace(/([\\;,":])/g, '\\$1');
    const escapeVcard = (value: string) => value.replace(/\\/g, '\\\\').replace(/([,;])/g, '\\$1').replace(/\n/g, '\\n');

    function buildPayload(): string {
      switch (activeTab) {
        case 'text':
          return $('qr-text').value.trim();
        case 'url': {
          const url = $('qr-url').value.trim();
          if (!url) return '';
          return /^[a-zA-Z][a-zA-Z0-9+.-]*:/.test(url) ? url : `https://${url}`;
        }
        case 'wifi': {
          const ssid = $('wifi-ssid').value.trim();
          if (!ssid) return '';
          const enc = ($('wifi-enc') as unknown as HTMLSelectElement).value;
          const pass = $('wifi-pass').value;
          const hidden = ($('wifi-hidden') as HTMLInputElement).checked;
          let payload = `WIFI:T:${enc};S:${escapeWifi(ssid)};`;
          if (enc !== 'nopass' && pass) payload += `P:${escapeWifi(pass)};`;
          if (hidden) payload += 'H:true;';
          return payload + ';';
        }
        case 'vcard': {
          const first = $('vc-first').value.trim();
          const last = $('vc-last').value.trim();
          if (!first && !last) return '';
          const lines = ['BEGIN:VCARD', 'VERSION:3.0'];
          lines.push(`N:${escapeVcard(last)};${escapeVcard(first)};;;`);
          lines.push(`FN:${escapeVcard([first, last].filter(Boolean).join(' '))}`);
          const phone = $('vc-phone').value.trim();
          const email = $('vc-email').value.trim();
          const org = $('vc-org').value.trim();
          const url = $('vc-url').value.trim();
          if (phone) lines.push(`TEL;TYPE=CELL:${escapeVcard(phone)}`);
          if (email) lines.push(`EMAIL:${escapeVcard(email)}`);
          if (org) lines.push(`ORG:${escapeVcard(org)}`);
          if (url) lines.push(`URL:${escapeVcard(url)}`);
          lines.push('END:VCARD');
          return lines.join('\n');
        }
        default:
          return '';
      }
    }

    function qrOptions(width: number) {
      return {
        width,
        margin: 2,
        errorCorrectionLevel: (logoImage
          ? 'H'
          : ($('qr-ecl') as unknown as HTMLSelectElement).value) as 'L' | 'M' | 'Q' | 'H',
        color: {
          dark: $('qr-fg').value,
          light: $('qr-bg').value,
        },
      };
    }

    function drawLogo(ctx: CanvasRenderingContext2D, size: number) {
      if (!logoImage) return;
      const logoSize = Math.round(size * 0.22);
      const pad = Math.round(logoSize * 0.12);
      const x = (size - logoSize) / 2;
      const y = (size - logoSize) / 2;
      ctx.fillStyle = $('qr-bg').value;
      ctx.beginPath();
      ctx.roundRect(x - pad, y - pad, logoSize + pad * 2, logoSize + pad * 2, pad);
      ctx.fill();
      ctx.drawImage(logoImage, x, y, logoSize, logoSize);
    }

    async function renderToCanvas(target: HTMLCanvasElement, size: number) {
      await QRCode.toCanvas(target, currentPayload, qrOptions(size));
      const ctx = target.getContext('2d');
      if (ctx) drawLogo(ctx, size);
    }

    async function update() {
      currentPayload = buildPayload();
      const hasContent = currentPayload.length > 0;
      pngBtn.disabled = !hasContent;
      svgBtn.disabled = !hasContent;

      if (!hasContent) {
        const ctx = canvas.getContext('2d');
        if (ctx) {
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
        }
        if (hint) hint.textContent = 'Start typing — your QR code updates live.';
        return;
      }

      try {
        await renderToCanvas(canvas, PREVIEW_SIZE);
        if (hint) hint.textContent = 'Scan with your phone camera to test.';
      } catch {
        if (hint) hint.textContent = 'Content is too long for a QR code — shorten it.';
        pngBtn.disabled = true;
        svgBtn.disabled = true;
      }
    }

    function setTab(tab: string) {
      activeTab = tab;
      tabButtons.forEach((btn) => {
        const active = btn.dataset.tab === tab;
        btn.setAttribute('aria-selected', String(active));
        btn.classList.toggle('bg-brand-600', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('border-brand-600', active);
        btn.classList.toggle('text-slate-600', !active);
      });
      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.panel !== tab);
      });
      void update();
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => setTab(btn.dataset.tab || 'url'));
    });

    root.querySelectorAll('input, textarea, select').forEach((el) => {
      el.addEventListener('input', () => void update());
      el.addEventListener('change', () => void update());
    });

    const logoInput = $('qr-logo');
    const logoRemove = document.getElementById('qr-logo-remove') as HTMLButtonElement;
    logoInput.addEventListener('change', () => {
      const file = logoInput.files?.[0];
      if (!file) return;
      const img = new Image();
      img.onload = () => {
        logoImage = img;
        logoRemove.classList.remove('hidden');
        void update();
      };
      img.src = URL.createObjectURL(file);
    });
    logoRemove.addEventListener('click', () => {
      logoImage = null;
      logoInput.value = '';
      logoRemove.classList.add('hidden');
      void update();
    });

    pngBtn.addEventListener('click', async () => {
      if (!currentPayload) return;
      const size = parseInt(($('qr-size') as unknown as HTMLSelectElement).value, 10);
      const offscreen = document.createElement('canvas');
      await renderToCanvas(offscreen, size);
      const link = document.createElement('a');
      link.download = `qrcode-${activeTab}.png`;
      link.href = offscreen.toDataURL('image/png');
      link.click();
    });

    svgBtn.addEventListener('click', async () => {
      if (!currentPayload) return;
      let svg = await QRCode.toString(currentPayload, {
        ...qrOptions(0),
        type: 'svg',
        width: undefined,
      });
      if (logoImage) {
        // Embed the logo as a data URI centered in the SVG's viewBox.
        const match = svg.match(/viewBox="0 0 (\d+) (\d+)"/);
        if (match) {
          const vb = parseInt(match[1], 10);
          const logoSize = vb * 0.22;
          const pad = logoSize * 0.12;
          const pos = (vb - logoSize) / 2;
          const c = document.createElement('canvas');
          c.width = logoImage.naturalWidth;
          c.height = logoImage.naturalHeight;
          c.getContext('2d')?.drawImage(logoImage, 0, 0);
          const dataUri = c.toDataURL('image/png');
          const overlay =
            `<rect x="${pos - pad}" y="${pos - pad}" width="${logoSize + pad * 2}" height="${logoSize + pad * 2}" rx="${pad}" fill="${$('qr-bg').value}"/>` +
            `<image x="${pos}" y="${pos}" width="${logoSize}" height="${logoSize}" href="${dataUri}"/>`;
          svg = svg.replace('</svg>', `${overlay}</svg>`);
        }
      }
      const blob = new Blob([svg], { type: 'image/svg+xml' });
      const link = document.createElement('a');
      link.download = `qrcode-${activeTab}.svg`;
      link.href = URL.createObjectURL(blob);
      link.click();
      URL.revokeObjectURL(link.href);
    });

    setTab(activeTab);
  }
</script>
